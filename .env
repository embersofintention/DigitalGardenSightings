STYLE_SETTINGS_CSS=body.css-settings-manager { --o-border: none; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header mk-readable-line mk-folder-lines mk-spaces-enabled mk-inline-context-enabled mk-flow-replace mk-flow-minimal css-settings-manager anp-td-none fas-hue theme-light is-maximized minimal-theme minimal-readable minimal-default-dark minimal-atom-light minimal-light minimal-dark colorful-active links-int-on links-ext-on img-grid minimal-status-off full-file-names minimal-folding chart-default-width table-default-width img-default-width iframe-default-width map-default-width o-red o-list-distinct o-headings-origami-smaller o-rainbow-headers-body o-header-line-h1 is-focused
USE_FULL_RESOLUTION_IMAGES=false
